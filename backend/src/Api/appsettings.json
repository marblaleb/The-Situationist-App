{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Database=situationist;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "situationist-api",
    "Audience": "situationist-client",
    "PublicKeyPem": "",
    "PrivateKeyPem": ""
  },
  "OAuth": {
    "Google": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "https://localhost:7000/auth/callback/google"
    },
    "Apple": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "https://localhost:7000/auth/callback/apple"
    }
  },
  "Ai": {
    "ApiKey": "",
    "MaxRequestsPerMinute": 20
  },
  "Events": {
    "MaxDurationMinutes": 60
  },
  "SignalR": {
    "GeohashPrecision": 5
  },
  "Cache": {
    "NearbyEventsTtlSeconds": 30,
    "NearbyMissionsTtlSeconds": 60
  }
}
